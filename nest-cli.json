{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "gateway": {
      "type": "application",
      "root": "src/gateway",
      "entryFile": "main",
      "sourceRoot": "src/gateway",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "users": {
      "type": "application",
      "root": "src/microservices/users",
      "entryFile": "main",
      "sourceRoot": "src/microservices/users",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "products": {
      "type": "application",
      "root": "src/microservices/products",
      "entryFile": "main",
      "sourceRoot": "src/microservices/products",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    }
  }
}